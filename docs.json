{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Bareconnect Partner API",
  "colors": {
    "primary": "#635bff",
    "light": "#7a73ff",
    "dark": "#4b44d6"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    },
    "groups": [
      {
        "group": "Getting started",
        "icon": "rocket",
        "pages": [
          "index.mdx",
          "base-url.mdx",
          "authentication.mdx",
          "scopes.mdx",
          "response-envelope.mdx",
          "errors.mdx",
          "rate-limiting.mdx"
        ]
      },
      {
        "group": "Identity",
        "icon": "fingerprint",
        "pages": [
          "endpoints/verify-key.mdx"
        ]
      },
      {
        "group": "Stores",
        "icon": "store",
        "pages": [
          "endpoints/stores/list.mdx",
          "endpoints/stores/get.mdx",
          "endpoints/stores/create.mdx",
          "endpoints/stores/update.mdx"
        ]
      },
      {
        "group": "Products",
        "icon": "box",
        "pages": [
          "endpoints/products/list.mdx",
          "endpoints/products/create.mdx",
          "endpoints/products/update.mdx",
          "endpoints/products/delete.mdx"
        ]
      },
      {
        "group": "Orders",
        "icon": "receipt",
        "pages": [
          "endpoints/orders/list.mdx",
          "endpoints/orders/get.mdx",
          "endpoints/orders/fulfill.mdx",
          "endpoints/orders/deliver.mdx",
          "endpoints/orders/confirm-payment.mdx"
        ]
      },
      {
        "group": "Webhooks",
        "icon": "webhook",
        "pages": [
          "endpoints/webhooks/list.mdx",
          "endpoints/webhooks/register.mdx",
          "endpoints/webhooks/remove.mdx",
          "endpoints/webhooks/deliveries.mdx",
          "endpoints/webhooks/events.mdx"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "href": "mailto:partners@bareconnect.com",
        "label": "Contact partners team"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get an API key",
      "href": "mailto:partners@bareconnect.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/bareconnect",
      "github": "https://github.com/bareconnect"
    }
  }
}
